# SurrealDB connection
SURREAL_HOST=http://localhost:8282
SURREAL_NS=flow_runner
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# Gemini API (free tier)
GEMINI_API_KEY=your-key-here

# Optional: paths
# FLOW_RUNNER_ROOT=/path/to/project
# FLOW_RUNNER_CWD=/path/to/working/dir
# FLOWS_DIR=/path/to/flows
# BUDGET_CHECK_SCRIPT=/path/to/check-budget.sh
# CODEX_SANDBOX_DIR=/path/to/sandbox
